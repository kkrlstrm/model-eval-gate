{
  "mode": "extract-accurate",
  "title": "Lead field extraction (title_seniority / function / org_type)",
  "note": "Frozen regression for the extraction modes. SYNTHETIC leads with unambiguous gold (two people would agree on every label). Guards against the mode's model silently drifting below its eval-verified agreement. Mirrors the Eval 1 / 1b schema.",
  "k": 3,
  "threshold": 0.66,
  "drift_tolerance": 0.12,
  "consistency_floor": 0.5,
  "baseline": {
    "meanScore": 0.967,
    "passHatK": 0.9,
    "model": "deepseek/deepseek-v4-flash",
    "verified_date": "2026-07-03"
  },
  "input_template": "Extract three fields from the lead below.\n\nValid values:\n- title_seniority: IC | Mgr | Dir | VP | C-suite | Board | Other\n- function: Leadership | Development | Programs | Grants_Finance | Admin_Operations | Academic | Board | Other\n- org_type: K12_District | Private_School | Foundation_Scholarship | University | Nonprofit | Association | Other\n\nDefinitions:\n- Leadership = CEO/Executive Director/President/Headmaster\n- Development = fundraising, advancement, donor relations\n- Programs = program managers/coordinators\n- Grants_Finance = grants admin/financial aid/scholarship admin\n- Academic = teachers, counselors, lecturers, curriculum\n- Board = trustees, board members, chair\n- Foundation_Scholarship = any foundation, scholarship-granting entity\n\nRespond with ONLY a JSON object {\"title_seniority\": \"...\", \"function\": \"...\", \"org_type\": \"...\"} — no prose, no markdown fences.\n\nLead:\nTitle: {{title}}\nCompany: {{company}}",
  "graders": [
    {
      "kind": "fieldAgreement",
      "name": "agreement",
      "fields": [
        "title_seniority",
        "function",
        "org_type"
      ]
    }
  ],
