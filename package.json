{
  "name": "model-eval-gate",
  "version": "0.1.0",
  "description": "A circuit breaker for cheap-model delegation. An eval-backed allowlist that lets agents use non-frontier models only where your own evals prove they are safe for that exact task, and refuses every other downgrade by default.",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "llm",
    "model-routing",
    "openrouter",
    "evals",
    "llmops",
    "governance"
  ],
  "scripts": {
    "route": "tsx src/cli.ts",
    "explain": "tsx src/cli.ts explain",
    "check": "tsx src/check.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/parity.ts && python3 test/parity.py",
    "ci": "npm run typecheck && npm run check && npm test",
    "regression": "tsx eval/regression.ts",
    "regression:baseline": "tsx eval/regression.ts --update-baseline",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@openrouter/agent": "^0.6.0",
    "@openrouter/sdk": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
